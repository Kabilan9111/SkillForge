nse:**```GET /api/roadmap/2?level=beginner```http### Python Full-Stack - Beginner Level## 📝 Example API Responses---```Authorization: Bearer <token>GET /api/roadmap/:trackId?level=intermediate```http### Get Roadmap for Specific Track```}  "error": "Invalid level. Must be one of: beginner, intermediate, advanced"{// Invalid level value}  "error": "Level parameter is required. Must be one of: beginner, intermediate, advanced"{// Missing level parameter```json**Error Responses:**- `level` (required): `beginner`, `intermediate`, or `advanced`**Query Parameters:**```Authorization: Bearer <token>GET /api/roadmap?level=beginner```http### Get Roadmap for Active Track## 🚀 API Endpoints---```}  });    error: 'Level parameter is required. Must be one of: beginner, intermediate, advanced'   return res.status(400).json({ if (!req.query.level) {// Level parameter is MANDATORYGET /api/roadmap/:trackId?level=beginner|intermediate|advanced```javascript**New Endpoint:**```GET /api/roadmap/:trackId  // No level filtering```javascript**Old Endpoint:**### 3. RoadmapController (`src/controllers/roadmapController.js`)```}  // Returns modules with level field included  // Calculate unlock status based on prerequisites    const modules = await Module.findByTrackAndLevel(trackId, level);  // Get modules for specific track AND level  }    throw { status: 400, message: 'Invalid level' };  if (!validLevels.includes(level)) {  const validLevels = ['beginner', 'intermediate', 'advanced'];  // Validate level parameterstatic async getRoadmapForTrackAndLevel(userId, trackId, level) {```javascript**New Method:**```}  // Returns ALL modules regardless of level  const modules = await Module.findByTrack(trackId);static async getRoadmapForTrack(userId, trackId) {```javascript**Old Method:**### 2. RoadmapService (`src/services/roadmapService.js`)```static async create(trackId, level, title, description, category, hours, order)```javascript**Updated create method:**```}  return await db.all(sql, [trackId, level]);  `;    ORDER BY m.sequence_order    GROUP BY m.id    WHERE m.track_id = ? AND m.level = ?    LEFT JOIN module_prerequisites mp ON m.id = mp.module_id    FROM modules m           GROUP_CONCAT(mp.prerequisite_id) as prerequisite_ids    SELECT m.*,   const sql = `static async findByTrackAndLevel(trackId, level) {```javascript**New Method:**```}  // Returns ALL modules for a track (all levels mixed)static async findByTrack(trackId) {```javascript**Old Method:**### 1. Module Model (`src/models/Module.js`)## 🔧 Backend Changes---- ✅ Sequence order resets per level (1, 2, 3...)- ✅ Prerequisites are within the same level- ✅ Modules are NEVER shared between levels- ✅ Each module belongs to ONE track AND ONE level**Key Rules:**```    └── ... (8 modules total)    ├── Module 3: Message Queues    ├── Module 2: Caching Strategies (Redis)    ├── Module 1: Microservices Architecture└── Advanced Level│   └── ... (7 modules total)│   ├── Module 3: Database Integration│   ├── Module 2: RESTful API Design│   ├── Module 1: Flask Web Framework├── Intermediate Level│   └── ... (6 modules total)│   ├── Module 3: Data Structures Basics│   ├── Module 2: Functions & Modules│   ├── Module 1: Python Fundamentals├── Beginner LevelTrack (e.g., Python Full-Stack)```### Data Model Structure```CREATE INDEX idx_modules_track_level ON modules(track_id, level);-- New index for performance);  FOREIGN KEY (track_id) REFERENCES tracks(id)  sequence_order INTEGER NOT NULL,  estimated_hours INTEGER DEFAULT 0,  category TEXT NOT NULL,  description TEXT,  title TEXT NOT NULL,  level TEXT NOT NULL CHECK(level IN ('beginner', 'intermediate', 'advanced')),  track_id INTEGER NOT NULL,  id INTEGER PRIMARY KEY AUTOINCREMENT,CREATE TABLE modules (```sql**modules table** - Added `level` field:### Database Schema Changes## 📊 Updated Data Model---**After**: Each level has completely distinct modules with proper backend validation.**Before**: All levels (Beginner, Intermediate, Advanced) returned the same roadmap modules.  ## 🎯 Problem Fixedconst User = require('../models/User');
const Track = require('../models/Track');
const Module = require('../models/Module');

const seedData = async () => {
  try {
    await db.connect();
    console.log('Starting data seeding...');

    // Create sample institutions
    const inst1 = await Institution.create('TechVidya College', 'college', 'Bangalore, India');
    const inst2 = await Institution.create('CodeMaster School', 'school', 'Mumbai, India');
    console.log('✓ Institutions created');

    // Create sample users
    await User.create(inst1, 'student1@techvidya.edu', 'password123', 'Rahul Sharma');
    await User.create(inst1, 'student2@techvidya.edu', 'password123', 'Priya Patel');
    await User.create(inst2, 'student3@codemaster.edu', 'password123', 'Amit Kumar');
    console.log('✓ Users created');

    // Create tracks
    await db.run(`
      INSERT INTO tracks (name, slug, description, color, display_order)
      VALUES 
        ('Java Development', 'java', 'Master Java programming from basics to advanced enterprise applications', '#f89820', 1),
        ('Python Development', 'python', 'Learn Python for web development, data science, and automation', '#3776ab', 2),
        ('C/C++ Development', 'c-cpp', 'Deep dive into system programming and competitive coding with C/C++', '#00599c', 3)
    `);
    console.log('✓ Tracks created');

    // Get track IDs
    const javaTrack = await Track.findBySlug('java');
    const pythonTrack = await Track.findBySlug('python');
    const cppTrack = await Track.findBySlug('c-cpp');

    // Seed Java modules (all levels)
    await seedJavaModules(javaTrack.id);
    console.log('✓ Java modules created');

    // Seed Python modules (all levels) - PRODUCTION-READY
    await seedPythonFullStackModules(pythonTrack.id);
    console.log('✓ Python Full-Stack modules created');

    // Seed C/C++ modules (all levels)
    await seedCppModules(cppTrack.id);
    console.log('✓ C/C++ modules created');

    console.log('\n🎉 Database seeded successfully!');
    console.log('\nSample credentials:');
    console.log('Email: student1@techvidya.edu');
    console.log('Password: password123');

  } catch (error) {
    console.error('Seeding failed:', error);
    throw error;
  }
};

async function seedJavaModules(trackId) {
  // BEGINNER LEVEL - Java Fundamentals
  const b1 = await Module.create(trackId, 'beginner', 'Java Basics & Syntax', 'Variables, data types, operators, control flow', 'fundamentals', 8, 1);
  const b2 = await Module.create(trackId, 'beginner', 'Object-Oriented Programming Basics', 'Classes, objects, methods, constructors', 'fundamentals', 10, 2);
  const b3 = await Module.create(trackId, 'beginner', 'String Manipulation', 'String class, StringBuilder, common operations', 'fundamentals', 6, 3);
  const b4 = await Module.create(trackId, 'beginner', 'Arrays Basics', 'Single and multi-dimensional arrays', 'data-structures', 8, 4);
  const b5 = await Module.create(trackId, 'beginner', 'Simple Calculator Project', 'Build a command-line calculator', 'projects', 12, 5);

  // INTERMEDIATE LEVEL - Java Advanced Concepts
  const i1 = await Module.create(trackId, 'intermediate', 'Inheritance & Polymorphism', 'Advanced OOP concepts, abstract classes, interfaces', 'fundamentals', 12, 1);
  const i2 = await Module.create(trackId, 'intermediate', 'Exception Handling', 'Try-catch, custom exceptions, best practices', 'fundamentals', 8, 2);
  const i3 = await Module.create(trackId, 'intermediate', 'Collections Framework', 'Lists, Sets, Maps, iterators', 'data-structures', 12, 3);
  const i4 = await Module.create(trackId, 'intermediate', 'File I/O & Streams', 'Reading/writing files, buffered streams', 'fundamentals', 10, 4);
  const i5 = await Module.create(trackId, 'intermediate', 'Banking System Project', 'Build a complete banking application', 'projects', 20, 5);

  // ADVANCED LEVEL - Enterprise Java
  const a1 = await Module.create(trackId, 'advanced', 'Multithreading & Concurrency', 'Threads, synchronization, concurrent collections', 'algorithms', 16, 1);
  const a2 = await Module.create(trackId, 'advanced', 'Design Patterns', 'Singleton, Factory, Observer, MVC patterns', 'algorithms', 14, 2);
  const a3 = await Module.create(trackId, 'advanced', 'Spring Boot REST APIs', 'Building RESTful services with Spring', 'projects', 20, 3);
  const a4 = await Module.create(trackId, 'advanced', 'Database Integration (JDBC/JPA)', 'Connecting to databases, ORM concepts', 'data-structures', 16, 4);
  const a5 = await Module.create(trackId, 'advanced', 'Microservices Architecture', 'Building scalable distributed systems', 'projects', 24, 5);

  // Prerequisites for beginner
  await Module.addPrerequisite(b2, b1);
  await Module.addPrerequisite(b3, b1);
  await Module.addPrerequisite(b4, b1);
  await Module.addPrerequisite(b5, b4);

  // Prerequisites for intermediate
  await Module.addPrerequisite(i2, i1);
  await Module.addPrerequisite(i3, i1);
  await Module.addPrerequisite(i4, i2);
  await Module.addPrerequisite(i5, i3);

  // Prerequisites for advanced
  await Module.addPrerequisite(a2, a1);
  await Module.addPrerequisite(a3, a2);
  await Module.addPrerequisite(a4, a3);
  await Module.addPrerequisite(a5, a4);
}
  await Module.addPrerequisite(m15, m14);
}

async function seedPythonFullStackModules(trackId) {
  // ============ BEGINNER LEVEL - Python Basics ============
  const b1 = await Module.create(trackId, 'beginner', 'Python Fundamentals', 'Variables, data types, operators, control structures', 'fundamentals', 8, 1);
  const b2 = await Module.create(trackId, 'beginner', 'Functions & Modules', 'Defining functions, parameters, modules, packages', 'fundamentals', 8, 2);
  const b3 = await Module.create(trackId, 'beginner', 'Data Structures Basics', 'Lists, tuples, dictionaries, sets', 'data-structures', 10, 3);
  const b4 = await Module.create(trackId, 'beginner', 'File Handling', 'Reading/writing files, CSV, JSON basics', 'fundamentals', 6, 4);
  const b5 = await Module.create(trackId, 'beginner', 'Basic OOP Concepts', 'Classes, objects, methods, attributes', 'fundamentals', 10, 5);
  const b6 = await Module.create(trackId, 'beginner', 'Todo List CLI Project', 'Build a command-line todo list app', 'projects', 12, 6);

  // ============ INTERMEDIATE LEVEL - Web Development & APIs ============
  const i1 = await Module.create(trackId, 'intermediate', 'Flask Web Framework', 'Routes, templates, request handling', 'fundamentals', 14, 1);
  const i2 = await Module.create(trackId, 'intermediate', 'RESTful API Design', 'HTTP methods, status codes, JSON responses', 'fundamentals', 12, 2);
  const i3 = await Module.create(trackId, 'intermediate', 'Database Integration (SQLAlchemy)', 'ORM, models, queries, migrations', 'data-structures', 16, 3);
  const i4 = await Module.create(trackId, 'intermediate', 'Authentication & JWT', 'User login, sessions, token-based auth', 'algorithms', 12, 4);
  const i5 = await Module.create(trackId, 'intermediate', 'Async Programming (asyncio)', 'Coroutines, async/await, concurrent operations', 'algorithms', 14, 5);
  const i6 = await Module.create(trackId, 'intermediate', 'API Testing (pytest)', 'Unit tests, integration tests, mocking', 'practice', 10, 6);
  const i7 = await Module.create(trackId, 'intermediate', 'Blog API Project', 'Full CRUD REST API with authentication', 'projects', 20, 7);

  // ============ ADVANCED LEVEL - Performance & Architecture ============
  const a1 = await Module.create(trackId, 'advanced', 'Microservices Architecture', 'Service decomposition, inter-service communication', 'algorithms', 18, 1);
  const a2 = await Module.create(trackId, 'advanced', 'Caching Strategies (Redis)', 'In-memory caching, cache invalidation, sessions', 'data-structures', 14, 2);
  const a3 = await Module.create(trackId, 'advanced', 'Message Queues (Celery/RabbitMQ)', 'Async tasks, background jobs, distributed systems', 'algorithms', 16, 3);
  const a4 = await Module.create(trackId, 'advanced', 'Database Optimization', 'Indexing, query optimization, connection pooling', 'data-structures', 12, 4);
  const a5 = await Module.create(trackId, 'advanced', 'System Design Principles', 'Load balancing, scaling, fault tolerance', 'algorithms', 16, 5);
  const a6 = await Module.create(trackId, 'advanced', 'Docker & Containerization', 'Containers, images, docker-compose, deployment', 'fundamentals', 14, 6);
  const a7 = await Module.create(trackId, 'advanced', 'CI/CD Pipeline Setup', 'GitHub Actions, automated testing, deployment', 'practice', 12, 7);
  const a8 = await Module.create(trackId, 'advanced', 'E-Commerce Platform Project', 'Scalable full-stack e-commerce system', 'projects', 40, 8);

  // ========== Prerequisites - Beginner Level ==========
  await Module.addPrerequisite(b2, b1);
  await Module.addPrerequisite(b3, b2);
  await Module.addPrerequisite(b4, b2);
  await Module.addPrerequisite(b5, b3);
  await Module.addPrerequisite(b6, b5);

  // ========== Prerequisites - Intermediate Level ==========
  await Module.addPrerequisite(i2, i1);
  await Module.addPrerequisite(i3, i2);
  await Module.addPrerequisite(i4, i3);
  await Module.addPrerequisite(i5, i2);
  await Module.addPrerequisite(i6, i4);
  await Module.addPrerequisite(i7, i6);

  // ========== Prerequisites - Advanced Level ==========
  await Module.addPrerequisite(a2, a1);
  await Module.addPrerequisite(a3, a1);
  await Module.addPrerequisite(a4, a2);
  await Module.addPrerequisite(a5, a3);
  await Module.addPrerequisite(a6, a5);
  await Module.addPrerequisite(a7, a6);
  await Module.addPrerequisite(a8, a7);
}

async function seedCppModules(trackId) {
  // BEGINNER LEVEL - C++ Fundamentals
  const b1 = await Module.create(trackId, 'beginner', 'C++ Syntax & Basics', 'Variables, data types, operators, control flow', 'fundamentals', 10, 1);
  const b2 = await Module.create(trackId, 'beginner', 'Functions & Scope', 'Function definition, parameters, scope rules', 'fundamentals', 8, 2);
  const b3 = await Module.create(trackId, 'beginner', 'Arrays & Pointers Intro', 'Basic arrays, pointer fundamentals', 'data-structures', 10, 3);
  const b4 = await Module.create(trackId, 'beginner', 'Basic OOP in C++', 'Classes, objects, constructors, destructors', 'fundamentals', 12, 4);
  const b5 = await Module.create(trackId, 'beginner', 'Student Management System', 'Simple CLI application', 'projects', 14, 5);

  // INTERMEDIATE LEVEL - Advanced C++
  const i1 = await Module.create(trackId, 'intermediate', 'Pointers & Memory Management', 'Deep dive into pointers, dynamic memory, smart pointers', 'fundamentals', 14, 1);
  const i2 = await Module.create(trackId, 'intermediate', 'STL Containers', 'Vector, list, map, set, algorithms', 'data-structures', 12, 2);
  const i3 = await Module.create(trackId, 'intermediate', 'Templates & Generic Programming', 'Function templates, class templates', 'algorithms', 12, 3);
  const i4 = await Module.create(trackId, 'intermediate', 'File I/O & Streams', 'File handling, stream manipulation', 'fundamentals', 10, 4);
  const i5 = await Module.create(trackId, 'intermediate', 'Library Management Project', 'Console-based application with file storage', 'projects', 18, 5);

  // ADVANCED LEVEL - Systems Programming
  const a1 = await Module.create(trackId, 'advanced', 'Multithreading & Concurrency', 'std::thread, mutexes, condition variables', 'algorithms', 16, 1);
  const a2 = await Module.create(trackId, 'advanced', 'Design Patterns in C++', 'Singleton, Factory, Observer, RAII', 'algorithms', 14, 2);
  const a3 = await Module.create(trackId, 'advanced', 'Network Programming', 'Sockets, TCP/IP, client-server architecture', 'data-structures', 16, 3);
  const a4 = await Module.create(trackId, 'advanced', 'Performance Optimization', 'Profiling, cache optimization, compiler optimizations', 'algorithms', 14, 4);
  const a5 = await Module.create(trackId, 'advanced', 'Game Engine Project', 'Build a simple 2D game engine', 'projects', 30, 5);

  // Prerequisites for beginner
  await Module.addPrerequisite(b2, b1);
  await Module.addPrerequisite(b3, b2);
  await Module.addPrerequisite(b4, b3);
  await Module.addPrerequisite(b5, b4);

  // Prerequisites for intermediate
  await Module.addPrerequisite(i2, i1);
  await Module.addPrerequisite(i3, i2);
  await Module.addPrerequisite(i4, i1);
  await Module.addPrerequisite(i5, i4);

  // Prerequisites for advanced
  await Module.addPrerequisite(a2, a1);
  await Module.addPrerequisite(a3, a2);
  await Module.addPrerequisite(a4, a3);
  await Module.addPrerequisite(a5, a4);
}

// Run if called directly
if (require.main === module) {
  seedData()
    .then(() => {
      console.log('Done!');
      process.exit(0);
    })
    .catch(err => {
      console.error(err);
      process.exit(1);
    });
}

module.exports = seedData;
