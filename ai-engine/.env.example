# SkillForge AI Engine — Environment Variables
# Copy to .env and fill in your values

# ── App ────────────────────────────────────────────
DEBUG=false
PORT=8001

# ── Database (PostgreSQL) ──────────────────────────
DATABASE_URL=postgresql+asyncpg://skillforge:password@localhost:5432/skillforge_ai

# ── OpenAI ────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Anthropic (fallback LLM) ──────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5

# ── GitHub (Layer 2 — Skill Verification) ─────────
GITHUB_TOKEN=ghp_...

# ── Neo4j (Layer 4 — Skill Graph) ─────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# ── ML Models ──────────────────────────────────────
SBERT_MODEL=all-MiniLM-L6-v2
CODEBERT_MODEL=microsoft/codebert-base
SALARY_MODEL_PATH=data/salary_model.joblib

# ── Storage ────────────────────────────────────────
UPLOAD_DIR=uploads
FAISS_INDEX_PATH=data/faiss_roles.index
VECTORSTORE_PATH=data/vectorstore
RAG_DOCS_PATH=data/kb

# ── Authentication ─────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Leave EMPTY to run in dev-bypass mode (auth skipped — local dev only).
JWT_SECRET=
# Set false to disable auth enforcement in development
REQUIRE_AUTH=true

# ── Logging ────────────────────────────────────────
# One of: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# Directory for rotating JSON log files
LOG_DIR=logs
